# D&D Character Consultant System - .gitignore
# Ignore Python cache and environment files
__pycache__/
*.pyc
*.pyo
*.pyd
.env
venv/
ENV/
.envrc

# Ignore Ollama Modelfile (contains custom model configuration)
Modelfile

# Ignore VSCode settings and tasks
.vscode/

# Ignore personal documentation folder
docs_personal/

# Ignore OS-specific files
.DS_Store
Thumbs.db
desktop.ini
*.ini

# Ignore user-generated data and logs
*.log
*.sqlite3
*.db

# =============================================================================
# USER-SPECIFIC GAME DATA (in game_data/ folder)
# =============================================================================
# All personal campaign content, characters, NPCs, items, and party config
# Example files are tracked for reference, actual user data is git-ignored

# Characters: Ignore all JSON files except examples
game_data/characters/*.json
!game_data/characters/class.example.json
!game_data/characters/aragorn.json
!game_data/characters/frodo.json
!game_data/characters/gandalf.json

# NPCs: Ignore all JSON files except examples  
game_data/npcs/*.json
!game_data/npcs/npc.example.json
!game_data/npcs/butterbur.json

!game_data/npcs/npc_full_profile.example.json

# Custom Items: Ignore registry, track example
game_data/items/custom_items_registry.json
!game_data/items/custom_items_registry.example.json
!game_data/items/custom_items.json

# Campaigns: Ignore ALL user-generated campaign content
# This includes _Campaign/, _Quest/, _Story/, _Adventure/ folders with:
# - Story files (001_*.md, etc.)
# - Session results (session_results_*.md)
# - Character development (*_suggestions.md, *_analysis.md)
# - Story hooks (story_hooks_*.md)
game_data/campaigns/*
!game_data/campaigns/.gitkeep
!game_data/campaigns/Example_Campaign/
# Backup and temp files anywhere in game_data
game_data/**/*.bak
game_data/**/*.tmp

# =============================================================================
# SYSTEM CACHES AND GENERATED CONTENT
# =============================================================================

# Ignore notebook checkpoints
.ipynb_checkpoints/

# Ignore RAG cache directory (wiki content downloads)
.rag_cache/
*.rag.json
rag_*.db

# =============================================================================
# NOTES ON TRACKED FOLDERS
# =============================================================================

# Ignore story drafts and temp files
story_drafts/
*.tmp

# Ignore test output and coverage reports
*.coverage
htmlcov/
.pytest_cache/

# Ignore Python cache in tests
tests/__pycache__/
tests/**/__pycache__/

# Ignore miscellaneous
*.swp
*.swo
~$*

# =============================================================================
# DDEV (Docker-based Drupal Development Environment)
# =============================================================================
# DDEV database snapshots
.ddev/db_snapshots/

# DDEV snapshots
.ddev/snapshots/

# DDEV local config overrides
.ddev/config.local.yaml

# DDEV router certificates
.ddev/*.crt
.ddev/*.key

# DDEV xhprof traces
.ddev/xhprof/

# Drupal docroot (managed by DDEV/Composer)
drupal/

# DDEV-generated docker-compose overrides
.ddev/docker-compose.*.yaml
!.ddev/docker-compose.*.example.yaml

# =============================================================================
# DRUPAL CMS (drupal-cms/ directory)
# =============================================================================

# Composer dependencies (managed at project level)
drupal-cms/vendor/
drupal-cms/composer.lock

# Drupal core and contributed modules/themes
drupal-cms/web/core/
drupal-cms/web/libraries/
drupal-cms/web/modules/contrib/
drupal-cms/web/profiles/contrib/
drupal-cms/web/themes/contrib/

# Site-specific files (database settings, uploaded files, etc.)
drupal-cms/web/sites/*/settings*.php
drupal-cms/web/sites/*/services*.yml
drupal-cms/web/sites/*/files/
drupal-cms/web/sites/*/private/
drupal-cms/web/sites/simpletest/

# PHP files scaffolded in web root
drupal-cms/web/*.php

# Drupal cache files
drupal-cms/web/sites/*/cache/
drupal-cms/web/sites/*/phpunit/

# PHP error logs
drupal-cms/*.log
drupal-cms/web/*.log

# OS-specific files in drupal-cms
drupal-cms/.DS_Store
drupal-cms/Thumbs.db

# DDEV configuration for drupal-cms
drupal-cms/.ddev/db_snapshots/
drupal-cms/.ddev/snapshots/
drupal-cms/.ddev/config.local.yaml
drupal-cms/.ddev/*.crt
drupal-cms/.ddev/*.key
drupal-cms/.ddev/xhprof/
drupal-cms/.ddev/docker-compose.*.yaml
