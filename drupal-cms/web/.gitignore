# Site-specific settings and files.
# settings.php and settings.ddev.php are safe to commit in a DDEV project.
/sites/*/settings.local.php
/sites/*/services.local.yml
/sites/*/files
/sites/*/private

# Test site directories generated by automated testing.
/sites/simpletest

# Dependencies managed by Composer.
/core
/libraries
/modules/contrib
/profiles/contrib
/themes/contrib

# PHP scripts scaffolded into the web root by Drupal core.
/*.php
