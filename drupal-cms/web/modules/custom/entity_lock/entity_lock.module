<?php

declare(strict_types=1);

/**
 * @file
 * Hook implementations for the Entity Lock module.
 */

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Access\AccessResultInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityPublishedInterface;
use Drupal\Core\Field\FieldDefinitionInterface;
use Drupal\Core\Field\FieldItemListInterface;
use Drupal\Core\Session\AccountInterface;

/**
 * Implements hook_entity_access().
 *
 * Blocks deletion of any entity in the locked list for all users. The lock
 * is absolute: the only way to delete a locked entity is to first remove it
 * from the locked list via the admin UI at /admin/config/system/entity-lock.
 *
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity being accessed.
 * @param string $operation
 *   The operation being performed (view, update, delete, etc.).
 * @param \Drupal\Core\Session\AccountInterface $account
 *   The user performing the operation.
 *
 * @return \Drupal\Core\Access\AccessResultInterface
 *   The access result.
 */
function entity_lock_entity_access(EntityInterface $entity, string $operation, AccountInterface $account): AccessResultInterface {
  if ($operation !== 'delete') {
    return AccessResult::neutral();
  }

  $config = \Drupal::config('entity_lock.settings');

  /** @var \Drupal\entity_lock\EntityLockManager $manager */
  $manager = \Drupal::service('entity_lock.manager');

  if (!$manager->isEntityLocked($entity)) {
    return AccessResult::neutral()->addCacheableDependency($config);
  }

  if (!$account->isAnonymous()) {
    $manager->showLockedMessage($entity, $manager->getReasonForEntity($entity));
  }

  return AccessResult::forbidden('This entity is locked and cannot be deleted.')
    ->addCacheableDependency($config);
}

/**
 * Implements hook_entity_field_access().
 *
 * Prevents the 'status' field from being edited on locked, published entities.
 * This closes the indirect workaround of unpublishing an entity instead of
 * deleting it to achieve a similar effect. The restriction applies to all
 * users; remove the lock via the admin UI to restore editing.
 *
 * @param string $operation
 *   The operation being performed (view or edit).
 * @param \Drupal\Core\Field\FieldDefinitionInterface $field_definition
 *   The field definition.
 * @param \Drupal\Core\Session\AccountInterface $account
 *   The user performing the operation.
 * @param \Drupal\Core\Field\FieldItemListInterface<\Drupal\Core\Field\FieldItemInterface>|null $items
 *   The field items, if available.
 *
 * @return \Drupal\Core\Access\AccessResultInterface
 *   The access result.
 */
function entity_lock_entity_field_access(string $operation, FieldDefinitionInterface $field_definition, AccountInterface $account, ?FieldItemListInterface $items = NULL): AccessResultInterface {
  if ($operation !== 'edit' || $field_definition->getName() !== 'status' || $items === NULL) {
    return AccessResult::neutral();
  }

  $entity = $items->getEntity();

  if (!($entity instanceof EntityPublishedInterface) || !$entity->isPublished()) {
    return AccessResult::neutral();
  }

  $config = \Drupal::config('entity_lock.settings');

  /** @var \Drupal\entity_lock\EntityLockManager $manager */
  $manager = \Drupal::service('entity_lock.manager');

  if (!$manager->isEntityLocked($entity)) {
    return AccessResult::neutral()->addCacheableDependency($config);
  }

  return AccessResult::forbidden('The status field of this entity is locked.')
    ->addCacheableDependency($config);
}
