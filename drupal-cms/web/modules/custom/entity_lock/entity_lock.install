<?php

declare(strict_types=1);

/**
 * @file
 * Install, update, and uninstall hooks for the Entity Lock module.
 */

/**
 * Implements hook_install().
 */
function entity_lock_install(): void {
  // Force a rebuild of node access to incorporate the new lock rules.
  node_access_needs_rebuild(TRUE);
  drupal_flush_all_caches();
}

/**
 * Implements hook_uninstall().
 */
function entity_lock_uninstall(): void {
  drupal_flush_all_caches();
}
