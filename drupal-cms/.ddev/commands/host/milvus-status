#!/bin/bash
## Description: Show Milvus connection health and entity counts via the Python app.
## Usage: milvus-status
## Example: "ddev milvus-status"

set -eu

# Run the Python CLI status command from the project root (one level up from drupal-cms)
cd "$(git -C "$(dirname "$0")" rev-parse --show-toplevel)/.." 2>/dev/null || cd ..

python3 dnd_consultant.py --milvus-status
