# AI Configuration for D&D Character Consultant System
# Copy this file to .env and fill in your configuration
#
# ALTERNATIVE: Use the centralized config system instead!
# Run the app and select "Configure Settings" from the main menu
# to create game_data/config.json with all settings in one place.
# Environment variables still work as a fallback.
#
# ============================================================================
# RECOMMENDED: Two-Model Setup (one creative, one fast)
# ============================================================================
# The system routes tasks to different models automatically:
#   Creative model: story_generation, combat_narration  (high quality, slower)
#   Fast model:     story_analysis, dc_evaluation, spotlight_analysis, embedding
#
# Example using Ollama with two local models:
#
# OPENAI_API_KEY=ollama
#
# Drupal AI module reads this env var via the Key module (ollama_no_auth key).
# Ollama does not require a real API key - any non-empty value works.
OLLAMA_API_KEY=ollama
#
# Creative model - for story writing and combat narration
# AI_CREATIVE_BASE_URL=http://localhost:11434/v1
# AI_CREATIVE_MODEL=
#
# Fast model - for analysis, RAG queries, and evaluation
# AI_FAST_BASE_URL=http://localhost:11434/v1
# AI_FAST_MODEL=
#
# Optional temperature and token overrides per profile:
# AI_CREATIVE_TEMPERATURE=0.9
# AI_CREATIVE_MAX_TOKENS=2000
# AI_FAST_TEMPERATURE=0.3
# AI_FAST_MAX_TOKENS=500

# ============================================================================
# Fallback: Single-Model Setup
# ============================================================================
# If only one model is configured, all tasks use it.
#
# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=  # Leave empty for default OpenAI
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local)
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=

# OpenRouter
# OPENAI_API_KEY=your-openrouter-api-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=

# ============================================================================
# Global AI Parameters (apply when no per-profile override is set)
# ============================================================================
# Temperature: Controls randomness (0.0 = deterministic, 2.0 = very random)
# AI_TEMPERATURE=0.7

# Max Tokens: Maximum length of generated responses
# AI_MAX_TOKENS=1000

# ============================================================================
# RAG (Retrieval-Augmented Generation) Configuration
# ============================================================================
# Enable wiki integration for lore-accurate story generation
# RAG_ENABLED=true

# Wiki base URL for your campaign setting (campaign lore)
# Examples:
#   Critical Role (Exandria): https://criticalrole.fandom.com/wiki
#   Forgotten Realms: https://forgottenrealms.fandom.com/wiki
#   Custom wiki: https://your-wiki.com/wiki
# RAG_WIKI_BASE_URL=https://criticalrole.fandom.com/wiki

# D&D Rules wiki base URL (for spell/ability lookups in combat)
# Used by combat narrator for accurate spell descriptions
# Default: D&D 5e Wiki (https://dnd5e.wikidot.com)
# RAG_RULES_BASE_URL=https://dnd5e.wikidot.com

# Cache settings
# RAG_CACHE_TTL=604800  # Time-to-live in seconds (default: 7 days)
# RAG_MAX_CACHE_SIZE=100  # Maximum number of cached pages
# RAG_CACHE_DIR=.rag_cache  # Directory for JSON cache files and default SQLite DB path
# RAG_CACHE_BACKEND=json  # Options: json, sqlite
# RAG_VECTOR_DB_PATH=.rag_cache/rag_cache.sqlite3  # Used when backend is sqlite

# Search settings
# RAG_SEARCH_DEPTH=3  # How many wiki links to follow (1-5)
# RAG_MIN_RELEVANCE=0.5  # Minimum relevance score (0.0-1.0)

# ============================================================================
# Milvus Vector Database (optional - semantic RAG retrieval)
# ============================================================================
# Set MILVUS_ENABLED=true to replace keyword search with semantic similarity.
# Requires Milvus running locally (see docker-compose.milvus.yml).
# MILVUS_ENABLED=false
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# Collection prefix - allows multiple projects to share one Milvus instance.
# MILVUS_COLLECTION_PREFIX=dnd

# The embedding model to use. Must match an OpenAI-compatible endpoint.
# For Ollama: use the name of a locally pulled embedding model.
# MILVUS_EMBEDDING_MODEL=

# Vector dimension must match the model output.
# MILVUS_EMBEDDING_DIM=

# Maximum results returned per semantic query.
# MILVUS_TOP_K=5

# Minimum cosine similarity (0.0-1.0) to include a result.
# MILVUS_SIMILARITY_THRESHOLD=0.7

# ============================================================================
# Drupal CMS Integration (optional - sync characters and stories to Drupal)
# ============================================================================
# Base URL of your Drupal site (e.g. https://drupal-cms.ddev.site for DDEV).
# DRUPAL_BASE_URL=https://drupal-cms.ddev.site

# Drupal credentials for JSON:API write access.
# DRUPAL_USER=
# DRUPAL_PASSWORD=

# Gatsby incremental build webhook (fired after --sync-drupal completes).
# Set via Drupal admin: Configuration -> Gatsby -> Settings.
# DRUPAL_GATSBY_WEBHOOK_URL=

# ============================================================================
# Per-Character Configuration
# ============================================================================
# Each character can have individual AI settings in their JSON file:
# {
#   "name": "Character Name",
#   "ai_config": {
#     "enabled": true,
#     "model": "gpt-4",
#     "temperature": 0.9,
#     "system_prompt": "You are a wise wizard...",
#     "max_tokens": 1500
#   }
# }
