# Copy to .env.development for local development.
# Never commit .env.development — it is gitignored.

# Server-side only (gatsby-config.ts, gatsby-node.ts)
DRUPAL_BASE_URL=https://drupal-cms.ddev.site
DRUPAL_USER=
DRUPAL_PASSWORD=

# Browser-exposed (GATSBY_ prefix required for client-side access)
# The gatsby_user account is read-only, so exposing these credentials is acceptable.
GATSBY_DRUPAL_BASE_URL=https://drupal-cms.ddev.site
GATSBY_DRUPAL_USER=
GATSBY_DRUPAL_PASSWORD=
