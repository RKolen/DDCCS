# Copy to .env.development for local development.
# Never commit .env.development — it is gitignored.
# No value in this file may be hardcoded — all must come from the environment.

# Site identity
SITE_URL=
SITE_TITLE=

# Server-side Drupal GraphQL sourcing uses ../.env:
# DRUPAL_BASE_URL=
# DRUPAL_GRAPHQL_TOKEN=

# Browser-exposed (GATSBY_ prefix required for client-side access).
# GATSBY_DRUPAL_BASE_URL powers browser-side admin links in console screens.
GATSBY_DRUPAL_BASE_URL=

# AI backend — displayed in the Settings and Model Profile screens.
# GATSBY_AI_MODELS: comma-separated model IDs shown in the Model Profile screen.
# GATSBY_AI_MODEL: the currently active model ID (must be one of GATSBY_AI_MODELS).
GATSBY_AI_MODEL=
GATSBY_AI_MODELS=
GATSBY_AI_BASE_URL=
GATSBY_AI_TEMPERATURE=
GATSBY_AI_MAX_TOKENS=

# RAG — displayed in the Settings screen.
GATSBY_RAG_WIKI_URL=
GATSBY_RAG_RULES_URL=
